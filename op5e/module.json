{
  "id": "op5e",
  "title": "One Piece 5e (Blood & Brine)",
  "description": "Unified OP5e Foundry module: compendium packs, character creator wizard, critical-damage rules, and optional JB2A/Sequencer animations.",
  "version": "0.2.6",
  "manifest": "https://github.com/Blood-and-Brine/blood-brine/releases/latest/download/module.json",
