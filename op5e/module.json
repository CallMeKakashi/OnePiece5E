  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "system": ["dnd5e"],
  "authors": [
    {
      "name": "Blood & Brine"
    }
  ],
  "esmodules": [
    "scripts/compendium.mjs",
    "scripts/character-creator.mjs"
  ],
  "styles": ["styles/module.css"],
