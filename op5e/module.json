  "relationships": {
    "recommends": [
      {
        "id": "lib-wrapper",
        "type": "module",
        "reason": "Dependency for several automation/animation modules in the OP5e stack"
      },
      {
        "id": "socketlib",
        "type": "module",
        "reason": "Socket helpers used by some automation/animation modules"
      },
      {
        "id": "dae",
        "type": "module",
        "reason": "Automated active effects on compendium features"
      },
      {
        "id": "midi-qol",
        "type": "module",
        "reason": "Attack/damage workflows and animation hooks"
      },
      {
        "id": "dnd5e-animations",
        "type": "module",
        "reason": "Animation database/routing for dnd5e actions (pairs with Sequencer/JB2A)"
      },
      {
        "id": "autoanimations",
        "type": "module",
        "reason": "Automated Animations integration for midi-qol workflows"
      },
      {
        "id": "psfx",
        "type": "module",
        "reason": "Optional particle/SFX effects used by animation stacks"
      },
      {
        "id": "sequencer",
        "type": "module",
        "reason": "JB2A animation playback"
      },
      {
        "id": "JB2A_DnD5e",
        "type": "module",
        "reason": "Free JB2A animation assets (Foundry module browser)"
      }
    ]
  },
