{
  "id": "op5e-compendium",
  "title": "One Piece 5e Compendium",
  "description": "Compendium packs for the One Piece D&D 5e homebrew system, including classes, subclasses, features, races, feats, items, and creations.",
  "version": "0.1.4",
  "manifest": "http://localhost:8080/module.json",
  "download": "http://localhost:8080/op5e-compendium.zip",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "system": ["dnd5e"],
  "authors": [
    {
      "name": "Blood & Brine"
    }
  ],
  "esmodules": ["scripts/module.mjs"],
  "packs": [
    {
      "name": "classes",
      "label": "OP5e Classes",
      "path": "packs/classes",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "subclasses",
      "label": "OP5e Subclasses",
      "path": "packs/subclasses",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "class-features",
      "label": "OP5e Class Features",
      "path": "packs/class-features",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "races",
      "label": "OP5e Races",
      "path": "packs/races",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "racial-features",
      "label": "OP5e Racial Features",
      "path": "packs/racial-features",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "feats",
      "label": "OP5e Feats",
      "path": "packs/feats",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "items",
      "label": "OP5e Items",
      "path": "packs/items",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "creations",
      "label": "OP5e Creations",
      "path": "packs/creations",
      "type": "Item",
      "system": "dnd5e"
    },
    {
      "name": "backgrounds",
      "label": "OP5e Backgrounds & Roles",
      "path": "packs/backgrounds",
      "type": "Item",
      "system": "dnd5e"
    }
  ],
  "packFolders": [
    {
      "name": "One Piece 5e",
      "packs": ["classes", "subclasses", "class-features", "races", "racial-features", "feats", "backgrounds", "items", "creations"]
    }
  ],
  "flags": {
    "dnd5e": {
      "types": {
        "class": { "sources": ["classes"] },
        "subclass": { "sources": ["subclasses"] },
        "feat": { "sources": ["class-features", "racial-features", "feats"] },
        "race": { "sources": ["races"] },
        "background": { "sources": ["backgrounds"] },
        "equipment": { "sources": ["items"] },
        "weapon": { "sources": ["items"] },
        "tool": { "sources": ["items"] },
        "consumable": { "sources": ["items"] },
        "loot": { "sources": ["items"] },
        "spell": { "sources": ["creations"] }
      },
      "sourceBooks": {
        "OP5e": {
          "label": "One Piece 5e",
          "abbreviation": "OP5e"
        }
      }
    }
  }
}
